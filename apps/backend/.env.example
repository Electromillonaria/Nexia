# App
NODE_ENV=development
PORT=8000
AUTH_PORT=8001
LOG_LEVEL=info

# Database
DATABASE_URL="file:./prisma/dev.db"
# DATABASE_URL="mysql://user:pass@host:3306/db" # MySQL producción

# JWT
# -----
# Desarrollo (HS256 - simple, un secreto):
# JWT_ALGORITHM=HS256 (default)
# JWT_SECRET=tu_secreto_aqui

# Producción (RS256 - asimétrico, más seguro):
# JWT_ALGORITHM=RS256
# JWT_PRIVATE_KEY_PATH=./keys/private.pem
# JWT_PUBLIC_KEY_PATH=./keys/public.pem
# También puedes usar variables directamente (una línea cada una):
# JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n..."
# JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n..."

JWT_EXPIRES_IN=8h

# Admin login (desarrollo)
ADMIN_USER=admin
ADMIN_PASSWORD=admin1234

# Google Gemini
# Obtén tu API key en: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=

# WhatsApp
WA_SESSION_PATH=./wa_session
WA_PUPPETEER_HEADLESS=true

# WooCommerce
# Obtén tus credenciales en: WooCommerce > Ajustes > API
WC_BASE_URL=
WC_CONSUMER_KEY=
WC_CONSUMER_SECRET=

# Redis (para BullMQ)
REDIS_URL=redis://localhost:6379